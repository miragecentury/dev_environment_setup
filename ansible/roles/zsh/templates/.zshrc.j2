export PATH="$HOME/bin:$HOME/.local/bin:$HOME/.opencode/bin:$HOME/.pulumi/bin:/usr/local/bin:$PATH"
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"
[ -d "{{ flutter_sdk_path }}/bin" ] && export PATH="{{ flutter_sdk_path }}/bin:$PATH"
{% if ansible_os_family == "Darwin" %}
export ANDROID_HOME="{{ '/opt/homebrew' if ansible_architecture == 'arm64' else '/usr/local' }}/share/android-commandlinetools"
{% else %}
export ANDROID_HOME="{{ android_sdk_root }}"
{% endif %}
export ANDROID_SDK_ROOT="$ANDROID_HOME"
export PATH="$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/platform-tools:$PATH"
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"


# GPG (Linux/WSL2 need GPG_TTY so pinentry can prompt in the terminal)
export GPG_TTY=$(tty)

# Zinit (self-bootstraps on first run)
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
[ ! -d $ZINIT_HOME ] && mkdir -p "$(dirname $ZINIT_HOME)"
[ ! -d $ZINIT_HOME/.git ] && git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"

zinit light zdharma-continuum/fast-syntax-highlighting
zinit light zsh-users/zsh-autosuggestions
zinit light zsh-users/zsh-completions

zinit snippet OMZL::git.zsh
zinit snippet OMZP::git

zstyle :omz:plugins:keychain agents gpg,ssh
zstyle :omz:plugins:keychain identities {{ ssh_identities | join(' ') }}
zstyle :omz:plugins:keychain options --quiet
zinit snippet OMZP::keychain

zinit snippet OMZP::ansible
zinit ice as"completion"
zinit snippet OMZP::docker
zinit ice as"completion"
zinit snippet OMZP::docker-compose
zinit snippet OMZP::ssh
zinit ice as"completion"
zinit snippet OMZP::poetry
zinit snippet OMZP::virtualenv
zinit snippet OMZP::kubectl
zinit snippet OMZP::kubectx
zinit snippet OMZP::sudo

# OpenSpec CLI completions (openspec completion install → ~/.oh-my-zsh/custom/completions)
[[ -d ~/.oh-my-zsh/custom/completions ]] && fpath=(~/.oh-my-zsh/custom/completions $fpath)

autoload -Uz compinit && compinit

# Oh My Posh (skip on macOS Terminal.app, which lacks glyph support)
if [ "$TERM_PROGRAM" != "Apple_Terminal" ]; then
  eval "$(oh-my-posh init zsh --config {{ omp_config }})"
fi

# commitizen (git cz) Jira prefix behavior
export CZ_JIRA_OPTIONAL="true"
export CZ_JIRA_LOCATION="pre-type"
export CZ_JIRA_PREPEND="["
export CZ_JIRA_APPEND="]"

# virtualenv prompt is rendered by the zsh plugin, not the venv itself
export VIRTUAL_ENV_DISABLE_PROMPT=true

export EDITOR='cursor --wait'

alias k=kubectl
alias kctx="kubectl-ctx"
alias kns="kubectl-ns"
alias kubectx="kubectl-ctx"
alias kubens="kubectl-ns"
alias tp="telepresence"
alias ll='ls -alF'
alias la='ls -A'

[[ $commands[kubectl] ]] && source <(kubectl completion zsh)
[[ $commands[k] ]] && source <(kubectl completion zsh)

# DeerHide agent skills updater
alias deerhide_agents_skills_update='npx --yes skills update -g -y'
