export PATH=$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=""

zstyle ':omz:update' mode auto
zstyle ':omz:update' frequency 7

plugins=(git ssh-agent gpg-agent kubectl keychain)

zstyle :omz:plugins:ssh-agent agent-forwarding yes
zstyle :omz:plugins:ssh-agent lifetime 4h
{% if ansible_os_family == "Debian" %}
zstyle :omz:plugins:ssh-agent helper keychain
zstyle :omz:plugins:keychain agents gpg,ssh
zstyle :omz:plugins:keychain identities {{ ssh_identities | join(' ') }}
{% endif %}

source $ZSH/oh-my-zsh.sh

eval "$(oh-my-posh init zsh --config https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/{{ omp_theme }}.omp.json)"

export ARCHFLAGS="-arch $(uname -m)"
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"

alias k=kubectl
alias kctx="kubectl-ctx"
alias kns="kubectl-ns"
alias kubectx="kubectl-ctx"
alias kubens="kubectl-ns"
